{
  "name": "personality-chatbot",
  "version": "1.0.0",
  "description": "Minimal chatbot website with selectable personalities and RAG-based knowledge",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "ingest:fetch": "node scripts/fetch_and_extract.js",
    "ingest:chunk": "node scripts/chunker.js",
    "ingest:embed": "node scripts/embed_and_index.js",
    "ingest:all": "npm run ingest:fetch && npm run ingest:chunk && npm run ingest:embed",
    "test": "node --test tests/*.test.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "optionalDependencies": {
    "@pinecone-database/pinecone": "^3.0.3",
    "openai": "^4.104.0",
    "weaviate-ts-client": "^1.6.0"
  }
}
