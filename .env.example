# Groq (FREE - recommended, get key at https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (free tier, get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local LLM (e.g. Ollama)
OLLAMA_URL=http://localhost:11434

# Web Search (optional - enhances web-search mode)
# SerpAPI: https://serpapi.com (free tier available)
SERP_API_KEY=

# Vector DB / embedding settings (examples)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DB=json

# Authentication (optional - leave empty for open access)
AUTH_PASSWORD=

# Server
PORT=52738
NODE_ENV=development
LOG_LEVEL=info

# Media API keys (optional)
OMDB_API_KEY=
TMDB_API_KEY=
SPORTSDB_API_KEY=1
